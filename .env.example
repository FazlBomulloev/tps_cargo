# Database
POSTGRES_USER=cargo
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=cargo_tps
DATABASE_URL=postgresql+asyncpg://cargo:changeme_strong_password@postgres:5432/cargo_tps

# JWT (>=32 chars random)
JWT_SECRET_KEY=replace-with-strong-random-32-plus-chars
API_BOT_SECRET=replace-with-another-random-32-plus-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# IPs of trusted reverse proxies allowed to set X-Forwarded-For (comma-separated).
# Leave empty unless the API sits behind a proxy/load balancer.
TRUSTED_PROXIES=

# Telegram bot
BOT_TOKEN=
CHANNEL_USERNAME=
CHANNEL_URL=

# Telegram admin user IDs (comma-separated)
ADMIN_IDS=620293106

# Redis (FSM storage + _check_sub cache). По умолчанию compose поднимает
# свой redis-сервис на redis://redis:6379/0. Оставь пусто чтобы использовать
# дефолт из compose, или укажи внешний URL.
REDIS_URL=

# Owner (initial seed)
OWNER_LOGIN=
OWNER_PASSWORD=
OWNER_FULL_NAME=
